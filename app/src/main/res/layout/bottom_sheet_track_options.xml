<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@color/gpm_background"
    android:paddingTop="16dp">

    <!-- Header / Track Info -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingHorizontal="16dp"
        android:paddingBottom="16dp"
        android:gravity="center_vertical">
        
        <ImageView
            android:id="@+id/bs_album_art"
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:scaleType="centerCrop"
            android:background="@color/gpm_gray_light" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:layout_marginStart="16dp">

            <TextView
                android:id="@+id/bs_track_title"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="16sp"
                android:textColor="@color/gpm_text_primary"
                android:textStyle="bold"
                android:maxLines="1"
                android:ellipsize="end"
                tools:text="Havana" />

            <TextView
                android:id="@+id/bs_track_artist"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="14sp"
                android:textColor="@color/gpm_text_secondary"
                android:maxLines="1"
                android:ellipsize="end"
                tools:text="Camila Cabello" />
        </LinearLayout>
    </LinearLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/gpm_gray_light" />

    <!-- Actions -->
    <TextView
        android:id="@+id/action_play_next"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:gravity="center_vertical"
        android:paddingHorizontal="16dp"
        android:text="@string/option_play_next"
        android:textSize="16sp"
        android:textColor="@color/gpm_text_primary"
        android:background="?attr/selectableItemBackground"
        android:clickable="true"
        android:focusable="true"/>

    <TextView
        android:id="@+id/action_add_to_queue"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:gravity="center_vertical"
        android:paddingHorizontal="16dp"
        android:text="@string/option_add_to_queue"
        android:textSize="16sp"
        android:textColor="@color/gpm_text_primary"
        android:background="?attr/selectableItemBackground"
        android:clickable="true"
        android:focusable="true"/>
        
    <TextView
        android:id="@+id/action_add_to_playlist"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:gravity="center_vertical"
        android:paddingHorizontal="16dp"
        android:text="@string/option_add_to_playlist"
        android:textSize="16sp"
        android:textColor="@color/gpm_text_primary"
        android:background="?attr/selectableItemBackground"
        android:clickable="true"
        android:focusable="true"/>

    <TextView
        android:id="@+id/action_go_to_artist"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:gravity="center_vertical"
        android:paddingHorizontal="16dp"
        android:text="@string/option_go_to_artist"
        android:textSize="16sp"
        android:textColor="@color/gpm_text_primary"
        android:background="?attr/selectableItemBackground"
        android:clickable="true"
        android:focusable="true"/>
        
    <TextView
        android:id="@+id/action_go_to_album"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:gravity="center_vertical"
        android:paddingHorizontal="16dp"
        android:text="@string/option_go_to_album"
        android:textSize="16sp"
        android:textColor="@color/gpm_text_primary"
        android:background="?attr/selectableItemBackground"
        android:clickable="true"
        android:focusable="true"
        android:layout_marginBottom="8dp"/>

</LinearLayout>
